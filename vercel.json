{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/healthspan", "destination": "/index.html" },
    { "source": "/unplug", "destination": "/index.html" },
    { "source": "/reset", "destination": "/index.html" },
    { "source": "/moms-reset", "destination": "/index.html" },
    { "source": "/work-well", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(png|jpg|jpeg|webp|avif)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(bundle|variants)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
